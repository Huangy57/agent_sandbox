#!/bin/bash --
# chaperon/stubs/srun — Chaperon-proxied srun stub
#
# All srun invocations go through the chaperon, which runs OUTSIDE the
# sandbox and has access to munge for Slurm authentication.  The chaperon
# handler validates flags and only allows step launching (SLURM_JOB_ID set).
#
# On the login node (no SLURM_JOB_ID), the handler rejects the request.
# On compute nodes (SLURM_JOB_ID set), the handler validates flags against
# a whitelist and execs real srun for job-step launching (MPI).
#
# Security: munge is intentionally blocked inside the sandbox.  Proxying
# srun through the chaperon provides munge access for step launching
# while preventing arbitrary job submission (flag whitelist + SLURM_JOB_ID
# check in the handler, which runs outside the sandbox).

set -euo pipefail

_STUB_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
source "$_STUB_DIR/_stub_lib.sh"

chaperon_call srun "$@"
exit $?
